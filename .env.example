# PostgreSQL
CHRONOS_POSTGRES_URL=postgresql+asyncpg://chronos:chronos@localhost:5432/chronos

# Redis
CHRONOS_REDIS_URL=redis://localhost:6379/0

# etcd
CHRONOS_ETCD_HOST=localhost
CHRONOS_ETCD_PORT=2379

# Master
CHRONOS_MASTER_HOST=0.0.0.0
CHRONOS_MASTER_PORT=8000
CHRONOS_NODE_ID=master-1

# Worker
CHRONOS_WORKER_HOSTNAME=worker-1
CHRONOS_WORKER_CPU_TOTAL=4.0
CHRONOS_WORKER_MEMORY_TOTAL=4096.0
CHRONOS_MASTER_URL=http://localhost:8000

# Scheduler
CHRONOS_SCHEDULER_INTERVAL_SECONDS=1.0
CHRONOS_HEARTBEAT_INTERVAL_SECONDS=5
CHRONOS_HEARTBEAT_TIMEOUT_SECONDS=15

# Logging
CHRONOS_LOG_LEVEL=INFO
CHRONOS_LOG_FORMAT=json
CHRONOS_ENVIRONMENT=development
